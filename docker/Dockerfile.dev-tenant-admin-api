# syntax=docker/dockerfile:1.4

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install --yes --no-install-recommends build-essential curl gcc pkg-config && \
    pip install --no-cache-dir uv && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

RUN uv sync --frozen --extra uvicorn --no-dev

EXPOSE 8000

ENV \
    TIGRBL_AUTH_PROFILE="production" \
    AUTHN_ISSUER="http://localhost:8016" \
    TIGRBL_AUTH_PROTECTED_RESOURCE_IDENTIFIER="http://localhost:8016/resource" \
    TIGRBL_AUTH_REQUIRE_TLS="false" \
    TIGRBL_AUTH_ADMIN_API_KEY="dev-tenant-admin-key" \
    TIGRBL_AUTH_ADMIN_API_KEY_DIR="/tmp/tigrbl-auth-tenant-admin" \
    PG_HOST="" \
    PG_PORT="5432" \
    PG_DB="" \
    PG_USER="" \
    PG_PASS="" \
    REDIS_HOST="" \
    REDIS_PASSWORD="" \
    PYTHONPATH="/app/pkgs/tigrbl-auth-api-tenant-admin/src:/app" \
    UV_PROJECT_ENVIRONMENT="/app/.venv"

CMD ["/app/.venv/bin/python", "-m", "uvicorn", "tigrbl_auth_api_tenant_admin:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info", "--proxy-headers"]
