{
  "name": "tigrbl-auth-uix-workspace",
  "private": true,
  "version": "0.3.5",
  "type": "module",
  "workspaces": [
    "apps/admin-uix",
    "apps/platform-admin-uix",
    "apps/tenant-admin-uix",
    "apps/developer-uix",
    "apps/service-admin-uix",
    "apps/my-account-uix",
    "apps/public-uix",
    "apps/rp"
  ],
  "scripts": {
    "build:admin-uix": "npm run build -w @tigrbl-auth/admin-uix",
    "build:platform-admin-uix": "npm run build -w @tigrbl-auth/platform-admin-uix",
    "build:tenant-admin-uix": "npm run build -w @tigrbl-auth/tenant-admin-uix",
    "build:developer-uix": "npm run build -w @tigrbl-auth/developer-uix",
    "build:service-admin-uix": "npm run build -w @tigrbl-auth/service-admin-uix",
    "build:my-account-uix": "npm run build -w @tigrbl-auth/my-account-uix",
    "build:public-uix": "npm run build -w @tigrbl-auth/public-uix",
    "build:rp": "npm run build -w @tigrbl-auth/rp",
    "build:uix": "npm run build:admin-uix && npm run build:platform-admin-uix && npm run build:tenant-admin-uix && npm run build:developer-uix && npm run build:service-admin-uix && npm run build:my-account-uix && npm run build:public-uix",
    "test:admin-uix": "npm run test -w @tigrbl-auth/admin-uix",
    "test:platform-admin-uix": "npm run test -w @tigrbl-auth/platform-admin-uix",
    "test:tenant-admin-uix": "npm run test -w @tigrbl-auth/tenant-admin-uix",
    "test:developer-uix": "npm run test -w @tigrbl-auth/developer-uix",
    "test:service-admin-uix": "npm run test -w @tigrbl-auth/service-admin-uix",
    "test:my-account-uix": "npm run test -w @tigrbl-auth/my-account-uix",
    "test:public-uix": "npm run test -w @tigrbl-auth/public-uix",
    "test:rp": "npm run test -w @tigrbl-auth/rp",
    "test:uix": "npm run test:admin-uix && npm run test:platform-admin-uix && npm run test:tenant-admin-uix && npm run test:developer-uix && npm run test:service-admin-uix && npm run test:my-account-uix && npm run test:public-uix"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^6.2.0",
    "typescript": "~5.8.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22"
  }
}
